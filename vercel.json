{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.1" },
    "frontend/pages/**/*.php": { "runtime": "vercel-php@0.7.1" }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/frontend/pages/(.*)", "dest": "/frontend/pages/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}